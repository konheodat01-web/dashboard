# Khối cấu hình nền tảng chung cho Reverse Proxy sang GitHub Pages
(github_proxy) {
    reverse_proxy https://konheodat01-web.github.io {
        header_up Host konheodat01-web.github.io
        transport http {
            tls
            tls_server_name konheodat01-web.github.io
        }
    }
}

# Khối cấu hình bảo mật cho phép trang mẹ nhúng các subdomain con
(subdomain_headers) {
    header {
        Content-Security-Policy "frame-ancestors 'self' https://nthieucloud.shop"
        X-Content-Type-Options "nosniff"
        X-XSS-Protection "1; mode=block"
    }
}

# 1. Trang trung chuyển chính (Dashboard) + Admin Panel
nthieucloud.shop, www.nthieucloud.shop {

    # MÀNG LỌC BẢO MẬT & MẠCH KHỬ CACHE HẠ TẦNG V68
    header {
        X-Content-Type-Options "nosniff"
        X-XSS-Protection "1; mode=block"
        Content-Security-Policy "frame-ancestors 'self' https://nthieucloud.shop"
        Permissions-Policy "geolocation=(), microphone=(), camera=()"
        
        # Chặn trình duyệt găm giữ file HTML cũ
        Cache-Control "no-cache, no-store, must-revalidate"
        Pragma "no-cache"
        Expires "0"
    }

    # Node.js Backend API & Admin Router (Port 3050)
    handle /admin* {
        reverse_proxy localhost:3050
    }
    handle /api* {
        reverse_proxy localhost:3050
    }

    # Trang chủ Dashboard: bốc giao diện tĩnh từ GitHub Pages
    handle {
        rewrite * /dashboard{uri}
        import github_proxy
    }
}

